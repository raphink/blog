---
interface Props {
    url: string;
    title: string;
    date: string;
    excerpt?: string;
    thumb?: string;
    seriesIndex?: number;
    lang?: string;
}

const { url, title, date, excerpt, thumb, seriesIndex, lang } = Astro.props;
const slug = url.replace(/^\/(?:fr\/)?posts\//, '').replace(/\/$/, '');
const thumbSrc = thumb || `/og/${slug}.png`;
const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
});
---
<article class="post post-card">
    <a class="post-card-banner" href={url}>
        <img src={thumbSrc} alt={title} />
    </a>
    <div class="post-card-body">
        <header class="post-header">
            <h2 class="post-title">
                {seriesIndex && <span class="series-index">{seriesIndex}</span>}
                <a href={url} rel="bookmark">{title}</a>
            </h2>
            <div class="post-meta">
                <time class="published" datetime={dateObj.toISOString().split('T')[0]}>{formattedDate}</time>
            </div>
        </header>
        {excerpt && (
            <div class="post-content"><p>{excerpt}</p></div>
        )}
        <p class="read-more">
            <a class="read-more-link" href={url}>
                {lang === 'fr' ? 'Lire la suite' : 'Keep reading'}
                <span class="icon-arrow-right" aria-hidden="true"></span>
            </a>
        </p>
    </div>
</article>
